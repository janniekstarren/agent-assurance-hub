# Chat provider for Module 8 (Ask).
#   mock  = offline, deterministic tool-calling simulation over the local mock
#           services (DEFAULT — used for the demo, no network required).
#   azure = call the dormant SWA /api/chat managed function, which proxies
#           Azure OpenAI / Azure AI Foundry (requires the function enabled and
#           the AZURE_OPENAI_* app settings — see README "Swap mock -> live").
VITE_CHAT_PROVIDER=mock
